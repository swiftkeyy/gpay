# ============================================
# DATABASE CONFIGURATION
# ============================================
# Option 1: Railway-style (RECOMMENDED for Railway deployment)
# Railway automatically provides DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual fields (for local development or custom setup)
# If DATABASE_URL is not set, these fields will be used
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=gpay
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password
# POSTGRES_SSL_MODE=require

# ============================================
# REDIS CONFIGURATION
# ============================================
# Option 1: Railway-style (RECOMMENDED for Railway deployment)
# Railway automatically provides REDIS_URL
REDIS_URL=redis://default:password@host:6379

# Option 2: Individual fields (for local development or custom setup)
# If REDIS_URL is not set, these fields will be used
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_SSL=false

# ============================================
# JWT & SECURITY
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# TELEGRAM BOT (REQUIRED)
# ============================================
# Get from @BotFather in Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Your bot username without @
BOT_USERNAME=your_bot_username

# ============================================
# PAYMENT PROVIDERS (OPTIONAL)
# ============================================
# YooKassa (Yandex Checkout)
YUKASSA_SHOP_ID=your-yukassa-shop-id
YUKASSA_SECRET_KEY=your-yukassa-secret-key

# Tinkoff
TINKOFF_TERMINAL_KEY=your-tinkoff-terminal-key
TINKOFF_SECRET_KEY=your-tinkoff-secret-key

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=your-cloudpayments-public-id
CLOUDPAYMENTS_API_SECRET=your-cloudpayments-api-secret

# Crypto Bot
CRYPTOBOT_API_TOKEN=your-cryptobot-token
CRYPTOBOT_ENABLED=true
CRYPTOBOT_API_BASE_URL=https://testnet-pay.crypt.bot/api

# ============================================
# CORS (REQUIRED)
# ============================================
# Set to * initially, update after frontend deployment
CORS_ORIGINS=*

# ============================================
# APP SETTINGS
# ============================================
APP_ENV=production
LOG_LEVEL=INFO
SHOP_NAME=Game Pay

# Admin Telegram IDs
SUPER_ADMIN_TG_ID=0
SECOND_ADMIN_TG_ID=0

# Commission & Rewards
PLATFORM_COMMISSION_PERCENT=5.0
REFERRAL_REWARD_PERCENT=5.0

# Auto-completion timeout (hours)
AUTO_COMPLETE_HOURS=72

# Telegram Stars
TELEGRAM_STARS_ENABLED=true
TELEGRAM_STARS_PER_RUB=0.5
